# Skopíruj do .env (lokálne) alebo nastav ako Environment Variables na Verceli.

# POVINNÉ — Gemini vízia (extrakcia z pôdorysu)
GEMINI_API_KEY=

# VOLITEĽNÉ — Claude (text kontrola + Opus eskalácia pri nízkej istote).
# Bez kľúča appka beží Gemini-only (graceful).
ANTHROPIC_API_KEY=

# VOLITEĽNÉ — výmena čítacieho modelu (model-agnostická architektúra, viď providers.py)
# EXTRACTOR_PROVIDER=anthropic          # default: gemini; anthropic = číta Claude/Fable
# ANTHROPIC_VISION_MODEL=claude-fable-5
# ANTHROPIC_PICK_MODEL=claude-haiku-4-5-20251001

# VOLITEĽNÉ overrides (default sú rozumné)
# GEMINI_VISION_MODEL=models/gemini-3.5-flash
# GEMINI_THINKING_BUDGET=512
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_VISION_MODEL=claude-opus-4-8
